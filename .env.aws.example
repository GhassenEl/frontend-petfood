# AWS EC2 + RDS (Terraform) — copier vers .env.aws
AWS_REGION=eu-west-3

# RDS endpoint (terraform output rds_endpoint)
DATABASE_URL=postgresql://petfood:CHANGE_ME@petfoodtn-production-postgres.xxxxx.eu-west-3.rds.amazonaws.com:5432/petfoodtn?schema=public

JWT_SECRET=CHANGE_ME_JWT_SECRET_MINIMUM_32_CHARACTERS!!
CORS_ORIGINS=https://app.petfoodtn.tn

# S3 uploads (terraform output s3_uploads_bucket)
AWS_S3_BUCKET=petfoodtn-production-uploads-123456789012

FASTAPI_URL=http://ml:8000
POSTGRES_USER=petfood
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=petfoodtn
