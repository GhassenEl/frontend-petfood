# Vite dev server
HOST=0.0.0.0
PORT=3001
DANGEROUSLY_DISABLE_HOST_CHECK=true
GENERATE_SOURCEMAP=false

# Proxy Vite -> backend Express (doit matcher backend/.env PORT, souvent 5002)
# VITE_API_PROXY_TARGET=http://127.0.0.1:5002
# Stripe (optional – frontend public key; message HTTP normal en dev localhost)
VITE_STRIPE_PK=pk_test_your_publishable_key

# Google Maps (optionnel – chargement à la demande, pas de script global)
# VITE_GOOGLE_MAPS_KEY=

# PayPal (optionnel — vide = mode démo côté API)
# VITE_PAYPAL_CLIENT_ID=

# JWT — validation côté frontend (doit correspondre au backend Express)
# VITE_JWT_ISSUER=petfoodtn
# VITE_JWT_AUDIENCE=petfoodtn-web
# VITE_JWT_EXPIRY_BUFFER_SEC=60
# VITE_JWT_REFRESH_THRESHOLD_SEC=300
