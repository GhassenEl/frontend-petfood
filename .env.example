# Vite dev server
HOST=0.0.0.0
PORT=3001
DANGEROUSLY_DISABLE_HOST_CHECK=true
GENERATE_SOURCEMAP=false

# Proxy Vite -> backend Express (doit matcher backend/.env PORT, souvent 5002)
# VITE_API_PROXY_TARGET=http://127.0.0.1:5002
# Stripe (optional – frontend public key; message HTTP normal en dev localhost)
VITE_STRIPE_PK=pk_test_your_publishable_key

# Google Maps (optionnel – chargement à la demande, pas de script global)
# VITE_GOOGLE_MAPS_KEY=

# PayPal (optionnel — vide = mode démo côté API)
# VITE_PAYPAL_CLIENT_ID=

# Sentry (optionnel — monitoring erreurs production)
# VITE_SENTRY_DSN=https://xxx@o000.ingest.sentry.io/000
# VITE_APP_RELEASE=petfoodtn@1.0.0

# JWT — validation côté frontend (doit correspondre au backend Express)
# VITE_JWT_ISSUER=petfoodtn
# VITE_JWT_AUDIENCE=petfoodtn-web
# VITE_JWT_EXPIRY_BUFFER_SEC=60
# VITE_JWT_REFRESH_THRESHOLD_SEC=300

# ESP32-CAM — flux vidéo live (optionnel ; démo locale : /videos/esp32-cam-demo.mp4)
# VITE_ESP32_CAM_MP4_URL=http://192.168.1.50/stream.mp4
# VITE_ESP32_CAM_MJPEG_URL=http://192.168.1.50:81/stream

# n8n — gestionnaire de tâches / workflows (voir docker-compose.n8n.yml)
# Dev : proxy Vite /n8n-webhook → http://127.0.0.1:5678/webhook  (npm run n8n:up)
VITE_N8N_WEBHOOK_URL=/n8n-webhook
# VITE_N8N_PROXY_TARGET=http://127.0.0.1:5678
# Prod : URL publique de votre instance n8n
# VITE_N8N_WEBHOOK_URL=https://n8n.votre-domaine.tn/webhook
