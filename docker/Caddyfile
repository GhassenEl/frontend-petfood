{
	email {$ACME_EMAIL}
}

# Production : définir DOMAIN=app.petfoodtn.tn dans .env.docker
{$DOMAIN} {
	encode gzip zstd
	reverse_proxy frontend:80
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com; connect-src 'self' https: wss:; frame-ancestors 'self';"
	}
}

# Fallback HTTP local (sans certificat) si DOMAIN=localhost
:80 {
	@notLocalHost not host localhost
	handle @notLocalHost {
		redir https://{host}{uri} permanent
	}
	reverse_proxy frontend:80
}
