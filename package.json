    "devops:aws:setup": "powershell -ExecutionPolicy Bypass -File scripts/devops/setup-aws.ps1",
    "devops:render:setup": "powershell -ExecutionPolicy Bypass -File scripts/devops/setup-render.ps1",
    "devops:render:health": "node scripts/devops/render-provision.mjs health",
    "devops:render:provision": "node scripts/devops/render-provision.mjs provision",
    "devops:render:status": "node scripts/devops/render-provision.mjs status",
    "devops:render:hooks": "node scripts/devops/render-provision.mjs hooks",
    "devops:render:github": "node scripts/devops/render-provision.mjs github",
    "devops:render:sync": "node scripts/devops/render-provision.mjs sync-github",
    "devops:prod:audit": "node scripts/devops/setup-prod.mjs audit",
    "devops:prod:sync": "node scripts/devops/setup-prod.mjs sync",
    "devops:deploy:check": "node scripts/devops/setup-prod.mjs audit",
    "devops:host": "node scripts/devops/host-application.mjs",
    "devops:host:render": "node scripts/devops/host-application.mjs --render",
    "demo:video": "node scripts/record-demo-video.js",
    "demo:video:5min": "cross-env DEMO_PACE=2.3 DEMO_HEADLESS=0 node scripts/record-demo-video.js",
    "demo:jury": "node scripts/record-jury-demo.js",
    "demo:jury:live": "cross-env DEMO_PACE=1.2 DEMO_HEADLESS=0 node scripts/record-jury-demo.js",
    "demo:marketing:mp4": "node scripts/record-marketing-demo.js",
