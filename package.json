    "seed:vet-live": "docker cp scripts/seedGuard.cjs petfood-backend:/app/scripts/seedGuard.cjs && docker cp scripts/seed-vet-live-data.cjs petfood-backend:/app/scripts/seed-vet-live-data.cjs && docker exec petfood-backend node /app/scripts/seed-vet-live-data.cjs",
    "seed:platform-live": "docker cp scripts/seedGuard.cjs petfood-backend:/app/scripts/seedGuard.cjs && docker cp scripts/seed-platform-live-data.cjs petfood-backend:/app/scripts/seed-platform-live-data.cjs && docker cp scripts/seed-vet-live-data.cjs petfood-backend:/app/scripts/seed-vet-live-data.cjs && docker exec petfood-backend node /app/scripts/seed-platform-live-data.cjs && docker exec petfood-backend node /app/scripts/seed-vet-live-data.cjs",
    "security:apply": "node scripts/apply-backend-security-patches.mjs",
    "devops:ci": "powershell -ExecutionPolicy Bypass -File scripts/devops/ci-local.ps1",
