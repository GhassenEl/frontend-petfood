# Copier vers .env.docker puis : docker compose --env-file .env.docker up -d --build

# PostgreSQL
POSTGRES_USER=petfood
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=petfood

# Backend
JWT_SECRET=change-me-super-secret-jwt-key-at-least-32-chars
DEMO_MODE=false
RUN_SEED=true
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Stripe (optionnel)
STRIPE_SECRET_KEY=
STRIPE_MOCK=1

# Ports exposés sur l'hôte
FRONTEND_PORT=8080
BACKEND_PORT=5002
ML_PORT=8000

# Fuseau horaire conteneurs
TZ=Africa/Tunis

# VPN WireGuard (docker-compose.vpn.yml) — npm run docker:vpn:up
VPN_SERVER_PORT=51820
VPN_PEERS=3
VPN_INTERNAL_SUBNET=10.13.13.0
# FEEDER_REQUIRE_VPN=true
# VPN_ALLOWED_CIDRS=10.13.13.0/24
