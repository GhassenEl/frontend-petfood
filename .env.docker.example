# Copier vers .env.docker puis : docker compose --env-file .env.docker up -d --build

# PostgreSQL
POSTGRES_USER=petfood
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=petfood

# Backend — production live (pas de données démo injectées)
JWT_SECRET=change-me-super-secret-jwt-key-at-least-32-chars
DEMO_MODE=false
RUN_SEED=false
AUTH_HTTPONLY_COOKIES=true
# Mettre true derrière HTTPS (Caddy) ; false pour Docker local :8080
AUTH_COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Seeds — obligatoire en production (NODE_ENV=production)
# SEED_SECRET=change-me-min-16-chars-random
# SEED_CONFIRM=<identique à SEED_SECRET>
# SEED_CLIENT_PASSWORD=<mot de passe fort pour nouveaux clients seed>

# Stripe (optionnel)
STRIPE_SECRET_KEY=
STRIPE_MOCK=1

# Ports exposés sur l'hôte
FRONTEND_PORT=8080
BACKEND_PORT=5002
ML_PORT=8000

# Fuseau horaire conteneurs
TZ=Africa/Tunis

# HTTPS (docker-compose.caddy.yml)
DOMAIN=app.petfoodtn.tn
ACME_EMAIL=admin@petfoodtn.tn

# CORS production — obligatoire avec votre domaine HTTPS
# CORS_ORIGINS=https://app.petfoodtn.tn

# Déploiement serveur web (scripts/devops/deploy-web-server.sh)
# 1. DNS A → IP du VPS
# 2. Ports 80 et 443 ouverts
# 3. DOMAIN + ACME_EMAIL + CORS_ORIGINS ci-dessus
# 4. sudo bash scripts/devops/deploy-web-server.sh /opt/petfoodtn

# Images GHCR (CD)
GHCR_OWNER=ghassenel
IMAGE_TAG=latest

# VPN WireGuard (docker-compose.vpn.yml) — npm run docker:vpn:up
VPN_SERVER_PORT=51820
VPN_PEERS=3
VPN_INTERNAL_SUBNET=10.13.13.0
# FEEDER_REQUIRE_VPN=true
# VPN_ALLOWED_CIDRS=10.13.13.0/24

# MQTT IoT (docker-compose.iot.yml)
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_BROKER_URL=mqtt://mqtt:1883
MQTT_TOPIC_PREFIX=petfood/

# Monitoring Prometheus / Grafana (docker-compose.monitoring.yml)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
# Backend : URL Grafana pour sondes (backend/.env)
# GRAFANA_URL=http://127.0.0.1:3000
# Frontend dev : proxy Vite /grafana -> Grafana (.env à la racine)
# VITE_GRAFANA_PROXY_TARGET=http://127.0.0.1:3000
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8081
METRICS_EXPORTER_PORT=9105
# Token admin optionnel — métriques BI (audience, vet) dans Prometheus
# METRICS_ADMIN_TOKEN=<jwt admin ou service token>
# Provisioning Grafana API (CI/CD — secrets GitHub GRAFANA_URL + GRAFANA_ADMIN_PASSWORD)
# GRAFANA_URL=https://grafana.votredomaine.tn
