# Copier vers terraform.tfvars (ne jamais committer terraform.tfvars)
aws_region   = "eu-west-3"
project_name = "petfoodtn"
environment  = "production"

# Optionnel — HTTPS avec domaine custom
# domain_name     = "app.petfoodtn.tn"
# certificate_arn = "arn:aws:acm:eu-west-3:123456789012:certificate/xxxxxxxx"
# cors_origins    = "https://app.petfoodtn.tn"

db_username = "petfood"
db_password = "CHANGE_ME_STRONG_PASSWORD_32_CHARS"
jwt_secret  = "CHANGE_ME_JWT_SECRET_MINIMUM_32_CHARACTERS!!"

image_tag     = "latest"
desired_count = 1
