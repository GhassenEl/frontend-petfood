{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "uid": "petfoodtn-overview",
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "title": "CPU hôte",
      "type": "stat",
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "title": "RAM utilisée",
      "type": "stat",
      "targets": [{ "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "title": "Commandes",
      "type": "stat",
      "targets": [{ "expr": "petfood_orders_total" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "title": "ESP32-CAM connectées",
      "type": "stat",
      "targets": [{ "expr": "petfood_esp32_cam_connected" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "title": "Latence API /health (ms)",
      "type": "timeseries",
      "targets": [{ "expr": "petfood_api_latency_ms" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "title": "Capteurs IoT actifs",
      "type": "timeseries",
      "targets": [{ "expr": "petfood_iot_sensors_active" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "title": "Qualité modèle IA",
      "type": "gauge",
      "targets": [{ "expr": "petfood_ml_model_quality_score" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "title": "Disponibilité API (blackbox)",
      "type": "timeseries",
      "targets": [{ "expr": "probe_success{job=\"blackbox-http\"}" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["petfoodtn", "devops"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "PetfoodTN — Monitoring temps réel",
  "uid": "petfoodtn-overview",
  "version": 1
